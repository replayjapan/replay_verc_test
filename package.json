{
  "name": "nxtpay-replay-domains",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "next -H 0.0.0.0",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "verify:types": "tsc --noEmit",
    "verify:build": "pnpm build",
    "verify:parity": "node -e \"const fs=require('fs'); if(!fs.existsSync('playwright.config.ts')&&!fs.existsSync('playwright.config.js')){console.log('No Playwright config — skipping parity');process.exit(0)}\" && playwright test",
    "verify:fast": "pnpm verify:types && pnpm verify:build",
    "verify:full": "pnpm verify:fast && pnpm verify:parity",
    "vercel-build": "cross-env NODE_OPTIONS=--no-deprecation payload migrate && cross-env NODE_OPTIONS=--no-deprecation next build"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.81.0",
    "@payloadcms/db-vercel-postgres": "3.81.0",
    "@payloadcms/live-preview-react": "3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/payload-cloud": "3.81.0",
    "@payloadcms/plugin-form-builder": "3.81.0",
    "@payloadcms/plugin-mcp": "3.81.0",
    "@payloadcms/plugin-nested-docs": "3.81.0",
    "@payloadcms/plugin-redirects": "3.81.0",
    "@payloadcms/plugin-search": "3.81.0",
    "@payloadcms/plugin-seo": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "budoux": "^0.8.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "csv-parse": "^6.1.0",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "16.2.2",
    "next-sitemap": "^4.2.3",
    "payload": "3.81.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@payloadcms/typescript-plugin": "^3.81.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.19",
    "copyfiles": "^2.4.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.2",
    "jsdom": "28.0.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
