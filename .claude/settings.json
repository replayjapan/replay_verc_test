{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "permissions": {
    "allow": [
  "Bash(pnpm build*)",
  "Bash(pnpm dev*)",
  "Bash(pnpm verify*)",
  "Bash(pnpm vitest*)",
  "Bash(pnpm payload*)",
  "Bash(npm run dev*)",
  "Bash(npm run build*)",
  "Bash(npx playwright screenshot*)",
  "Bash(curl *)",
  "Bash(cat *)",
  "Bash(ls *)",
  "Bash(grep *)",
  "Bash(find *)",
  "Bash(head *)",
  "Bash(tail *)",
  "Bash(wc *)",
  "Bash(mkdir *)",
  "Bash(zip *)",
  "Bash(unzip *)",
  "Bash(diff *)",
  "Bash(echo *)",
  "Bash(sort *)",
  "Bash(jq *)",
  "Bash(git status*)",
  "Bash(git log*)",
  "Bash(git diff*)",
  "Bash(git branch*)",
  "Bash(git add*)",
  "Bash(git commit*)",
  "Bash(git push*)",
  "Bash(git remote*)",
  "Bash(git checkout*)",
  "Bash(git merge*)",
  "Bash(bash scripts/*)",
  "mcp__payload-cms__find*",
 "Bash(pnpm exec playwright *)",
 "Bash(PLAYWRIGHT_BASE_URL=http://localhost:3000 pnpm exec playwright *)"
  
],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.credentials/**)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.config/gh/*)",
      "Read(~/.netrc)",
      "Bash(pkill *)",
      "Bash(killall *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-db-delete.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-push-main.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/verify-before-push.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/working-dir-guard.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-npx.sh" }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/checkpoint-reminder.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-types-after-edit.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/review-screenshot.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-context.sh" }
        ]
      }
    ]
  }
}
